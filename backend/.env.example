# Copy to .env and adjust. SQLite for dev:
DATABASE_URL="file:./dev.db"
# Production example (Postgres) — also set datasource provider to "postgresql":
# DATABASE_URL="postgresql://user:password@host:5432/fripa?schema=public"

# Admin dashboard auth (single admin account). Set strong values in production.
ADMIN_PASSWORD="changeme-admin"
ADMIN_JWT_SECRET="dev-fripa-jwt-secret-change-in-prod"

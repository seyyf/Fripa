// Fripa data model. SQLite for local dev (zero infra); swap the datasource
// provider to "postgresql" for production — the model stays the same.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// A second-hand piece. Mirrors the `TShirt` shape used across the app, plus a
// lifecycle `status` (one-off stock) and audit timestamps. SQLite has no native
// enums, so `size` / `condition` / `category` / `status` are stored as text and
// validated in application code against the TypeScript unions.
model Item {
  id          String   @id
  title       String
  description String
  imageUrl    String
  images      String? // JSON array of extra photo URLs (cover is imageUrl)
  price       Int
  salePrice   Int? // optional discounted price; treated as a sale only when < price
  size        String // S | M | L | XL | XXL
  brand       String
  condition   String // Comme neuf | Très bon état | Bon état | Vintage
  color       String
  seller      String
  category    String // T-shirts | Sweats | Polos | Vestes | Maillots | Shorts | Jeans
  status      String   @default("active") // active | draft | sold | archived
  cost        Int      @default(0) // what the shop paid for the piece (souk price); powers margin
  // Drop scheduling: a draft with a publishAt goes active automatically at that
  // time (and feeds the public "next drop" countdown teaser).
  publishAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// A placed order (cash on delivery for now). Lines snapshot the piece details at
// purchase time, so order history stays accurate even if the item is later
// edited or deleted.
model Order {
  id              String      @id @default(cuid())
  ref             String      @unique
  userId          String
  customerName    String
  customerEmail   String
  customerAddress String
  customerPhone   String
  governorate     String      @default("") // delivery zone (Tunisian governorate)
  total           Int // grand total: items − discount + deliveryFee
  deliveryFee     Int         @default(0) // 0 when free delivery applied
  status          String      @default("Nouvelle") // Nouvelle | Confirmée | Expédiée | Livrée | Retournée | Annulée
  paid            Boolean     @default(false) // cash collected (COD reconciliation)
  promoCode       String? // applied promo code, if any
  discount        Int         @default(0) // amount discounted off the original cart total
  // Loyalty stamp card: this order consumed a "free delivery" reward.
  loyaltyApplied  Boolean     @default(false)
  // Referral (parrainage): the code this buyer used, the TND it saved them, and
  // whether this order consumed one of the referrer's free-delivery credits.
  referredByCode      String?
  referralDiscount    Int     @default(0)
  referrerRewardApplied Boolean @default(false)
  createdAt       DateTime    @default(now())
  lines           OrderLine[]
}

// Shop configuration editable from the admin (delivery fees, bundle rule,
// WhatsApp numbers). One row per key; values are JSON-encoded.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// A shopper account, identified by phone (OTP login). No password.
model User {
  id           String         @id @default(cuid())
  phone        String         @unique
  name         String?
  address      String?
  email        String?
  referralCode String?        @unique // personal parrainage code (generated on first login)
  createdAt    DateTime       @default(now())
  favorites    FavoriteItem[]
}

// A favorited piece, persisted per account so favorites sync across devices.
model FavoriteItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId    String
  createdAt DateTime @default(now())

  @@unique([userId, itemId])
}

// A shopper interaction worth analysing: swipes (pass / keep / favorite) and
// cart-hold expiries. Phantom-crowd snatches are NOT recorded — they would
// pollute the demand signal. Powers the admin "Analyses" page.
model SwipeEvent {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  action    String // pass | keep | favorite | cart_expired
  createdAt DateTime @default(now())

  @@index([itemId])
  @@index([action])
}

// A discount code applied at checkout.
model PromoCode {
  id        String    @id @default(cuid())
  code      String    @unique // stored uppercase
  type      String // "percent" | "fixed"
  value     Int // percent (0-100) or fixed TND off
  minOrder  Int? // minimum cart total to qualify
  maxUses   Int? // null = unlimited
  uses      Int       @default(0)
  active    Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

model OrderLine {
  id       String @id @default(cuid())
  orderId  String
  order    Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemId   String
  title    String
  brand    String
  price    Int
  cost     Int    @default(0) // snapshot of the piece's cost at sale (realized margin)
  size     String
  imageUrl String
}

// Append-only record of admin actions, for accountability. Written from the
// admin services; surfaced read-only on the "Journal" page.
model AuditLog {
  id        String   @id @default(cuid())
  actor     String // who acted (admin role for now; ready for named accounts later)
  action    String // e.g. item.update, order.status, settings.update, items.markdown
  target    String? // human-readable subject (item title, order ref, …)
  detail    String? // short description of what changed
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Hourly rollup of live-visitor presence, for day-over-day traffic charts.
// `governorates` holds the peak-hour breakdown as JSON [{ name, count }].
model VisitorSnapshot {
  id           String   @id @default(cuid())
  hour         DateTime @unique
  peakOnline   Int
  avgOnline    Int
  governorates String   @default("[]") // JSON string (SQLite has no JSON type)
  createdAt    DateTime @default(now())
}
